# Copy to .env and adjust if needed. .env is gitignored.

# Postgres
POSTGRES_DB=medreg
POSTGRES_USER=medreg
POSTGRES_PASSWORD=medreg

# Grafana admin (first login uses these; Grafana will prompt to change)
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# Host-port bindings.
#   0  = random ephemeral port on 0.0.0.0 (reachable from the LAN)
#   N  = pin to a specific port (e.g. 3000)
# Discover the assigned port with:
#   docker compose port grafana 3000
#   docker compose port adminer 8080
GRAFANA_PORT=0
ADMINER_PORT=0
